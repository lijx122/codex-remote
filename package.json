{
  "name": "codex-remote",
  "version": "1.1.2",
  "private": true,
  "bin": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "node packages/codex-follower-core/test/list-threads.test.js && node packages/codex-follower-core/test/send-warm.test.js && node packages/codex-follower-core/test/app-server-transport.test.js && node packages/codex-control-plane/test/send-retry.test.js",
    "build": "pkg app.js --targets node18-win-x64 --output CodexRemote.exe"
  },
  "pkg": {
    "scripts": [
      "tools/**/*.js",
      "adapters/**/*.js",
      "packages/**/*.js"
    ],
    "assets": [
      "adapters/web/**/*"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
